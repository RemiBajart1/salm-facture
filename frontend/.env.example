# Variables d'environnement frontend LocaGest
# Copier ce fichier en .env.local et adapter les valeurs

# ── Mode mocks MSW (dev sans backend) ──────────────────────────────────────
# true (défaut en dev) : MSW intercepte tous les appels API avec des données fictives
# false : les appels passent vers le backend réel (proxy Vite → BACKEND_URL)
VITE_USE_MOCK=true

# ── Backend local (si VITE_USE_MOCK=false) ─────────────────────────────────
# URL du backend Micronaut local ou SAM local (dans .env.local, sans préfixe VITE_)
# BACKEND_URL=http://localhost:8080

# ── Cognito (ignoré si VITE_USE_MOCK=true) ─────────────────────────────────
VITE_COGNITO_USER_POOL_ID=eu-west-3_XXXXXXXX
VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
