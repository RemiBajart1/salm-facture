<?xml version="1.0" encoding="UTF-8"?>
<!--
    Tests d'intégration — doivent tourner dans le container Docker WordPress.
    Lancer avec : docker exec -it salm-facture-wordpress-1 bash -c "cd /var/www/html/wp-content/plugins/locagest && vendor/bin/phpunit -c phpunit-integration.xml"
-->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="tests/bootstrap-integration.php"
         colors="true"
         stopOnFailure="false">

    <testsuites>
        <testsuite name="Integration">
            <directory>tests/Integration</directory>
        </testsuite>
    </testsuites>

</phpunit>
