# Copier ce fichier en .env et ajuster les valeurs si nécessaire.
# Les valeurs par défaut suffisent pour le développement local.

# ── MariaDB ───────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=locagest_wp
MYSQL_USER=locagest
MYSQL_PASSWORD=locagest

# ── LocaGest ──────────────────────────────────────────────────────────────────
# Clé secrète pour signer les tokens JWT — OBLIGATOIREMENT différente en production
LOCAGEST_JWT_SECRET=dev-secret-key-changeme
